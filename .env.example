# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com/dashboard
# Project Settings > API Keys

# Your Supabase project URL
# Format: https://[project-id].supabase.co
# Example (replace with your project ID):
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public API key (ANON KEY - JWT format starting with eyJ)
# ⚠️ IMPORTANT: Use the ANON KEY (JWT token), NOT the service_role key
# This key is safe to expose in browser builds when using Row Level Security.
# Format: Should start with 'eyJ' and be ~200+ characters long
# DO NOT use keys starting with 'sb_' - those are service role keys
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJhbm9uIiwiaWF0IjoyMDI0MDEwMTAwLCJleHAiOjIwMzAwMDAwMDB9.your-signature-here

# Project ID (optional, helps with debugging)
VITE_SUPABASE_PROJECT_ID=your-project-id

# Optional: Temporary test overrides (development only). Do NOT set these in production.
# VITE_SUPABASE_TEST_URL=https://your-temp-project.supabase.co
# VITE_SUPABASE_TEST_KEY=your-temp-key

# Firebase Hosting Configuration (optional, if deploying to Firebase Hosting)
# FIREBASE_API_KEY=your_firebase_api_key
# FIREBASE_PROJECT_ID=your_firebase_project_id

# Development only - useful for debugging
# Set to 'true' to enable verbose Supabase logging
VITE_DEBUG_SUPABASE=false

# ===== SETUP INSTRUCTIONS =====
# 1. Copy this file to .env: cp .env.example .env
# 2. Update VITE_SUPABASE_URL with your project URL
# 3. Update VITE_SUPABASE_PUBLISHABLE_KEY with your ANON KEY (not service_role key)
# 4. Run: npm run dev OR node verify-setup.js (to check config first)
#
# Need help? See SETUP_AND_TROUBLESHOOTING.md or run: node verify-setup.js
